# Logging
LOG_LEVEL=INFO

# RabbitMQ (shared connection)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_EXCHANGE_NAME=cognibrew.inference
RABBITMQ_QUEUE_NAME=cognibrew.inference.face_embedded
RABBITMQ_FACE_EMBEDDED_ROUTING_KEY=face.embedded
RABBITMQ_FACE_RECOGNIZED_ROUTING_KEY=face.recognized
RABBITMQ_FACE_UNKNOWN_ROUTING_KEY=face.unknown

# Person Sync (cloud → vectordb)
PERSON_SYNC_EXCHANGE_NAME=cognibrew.vectordb
PERSON_SYNC_QUEUE_NAME=cognibrew.vectordb.person_updated
PERSON_SYNC_ROUTING_KEY=person.updated

# Qdrant (USE grpc)
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_COLLECTION_NAME=face_embeddings
QDRANT_EMBEDDING_DIM=512

# Model
MODEL_SIMILARITY_THRESHOLD=0.65
